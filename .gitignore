# Python
__pycache__/
*.py[cod]
*.egg-info/

# Virtual environment (never commit — it's huge and OS-specific)
venv/
.venv/

# Local database (contains password hashes + session tokens — keep out of git)
db.sqlite3
db.sqlite3-journal

# Collected static files (regenerated by collectstatic on deploy)
staticfiles/

# Secrets / local env
.env
*.env

# Editor / OS cruft
.DS_Store
*.log
.idea/
.vscode/
